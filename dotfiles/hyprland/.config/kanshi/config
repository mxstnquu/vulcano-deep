output "HDMI-A-1" {
  mode 2560x1440@144
  scale 1
  position 1536,0
  transform normal
  alias $EXTERNAL
}

output "eDP-1" {
  mode 1920x1080@144
  scale 1.25
  position 0,0
  transform normal
  alias $INTERNAL
}

profile external {
  output $INTERNAL disable
  output $EXTERNAL enable
}

profile standart {
  output $INTERNAL enable
  output $EXTERNAL enable 
}
